<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <!-- User message (right aligned) -->
    <LinearLayout
        android:id="@+id/user_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_user_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:text="User message"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:background="@drawable/bg_user_bubble"
            android:padding="12dp" />
    </LinearLayout>

    <!-- Assistant message (left aligned) -->
    <LinearLayout
        android:id="@+id/assistant_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="20sp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_assistant_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:text="Assistant message"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/bg_assistant_bubble"
                android:padding="12dp" />

            <Button
                android:id="@+id/btn_play_audio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 ကြားကြည့်"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="0dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
