<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_background"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tutor_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_blue"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- Language Mode Toggles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_lang_myanmar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/lang_myanmar"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_mode_selected"
                android:textColor="@color/text_white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />

            <Button
                android:id="@+id/btn_lang_russian"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_russian"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_mode_unselected"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <!-- Tutor Mode Scroll -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_mode_conversation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/mode_conversation"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tutor_mode_selected"
                    android:textColor="@color/text_white"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />

                <Button
                    android:id="@+id/btn_mode_pronunciation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/mode_pronunciation"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_mode_unselected"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />

                <Button
                    android:id="@+id/btn_mode_grammar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/mode_grammar"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_mode_unselected"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />

                <Button
                    android:id="@+id/btn_mode_vocabulary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_vocabulary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_mode_unselected"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Messages List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tutor_empty_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tutor_empty_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:padding="16dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_message_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/input_hint_myanmar"
            android:textSize="14sp"
            android:background="@drawable/bg_input_field"
            android:padding="12dp"
            android:maxLines="3"
            android:inputType="textMultiLine" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/accent_blue"
            android:contentDescription="Send" />
    </LinearLayout>

</LinearLayout>
