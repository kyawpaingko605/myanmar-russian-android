<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tutor_title"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_blue"
                android:contentDescription="Settings"
                android:scaleType="centerInside" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lang_myanmar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_myanmar"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="10dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lang_russian"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_russian"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                app:backgroundTint="#E5E5EA"
                app:cornerRadius="10dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_conversation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_conversation"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    app:backgroundTint="@color/accent_blue"
                    app:cornerRadius="14dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_pronunciation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_pronunciation"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    app:backgroundTint="#F2F2F7"
                    app:cornerRadius="14dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_grammar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_grammar"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    app:backgroundTint="#F2F2F7"
                    app:cornerRadius="14dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_vocabulary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_vocabulary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    app:backgroundTint="#F2F2F7"
                    app:cornerRadius="14dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeWidth="0dp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tutor_empty_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tutor_empty_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/background"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#E5E5EA"
            app:strokeWidth="1dp"
            android:layout_marginEnd="12dp">

            <EditText
                android:id="@+id/et_message_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/input_hint_myanmar"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@null"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:inputType="textShortMessage"
                android:maxLines="4" />
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_send"
            android:background="@android:color/transparent"
            android:tint="@color/accent_blue"
            android:contentDescription="Send message"
            android:scaleType="centerInside" />
    </LinearLayout>

</LinearLayout>
